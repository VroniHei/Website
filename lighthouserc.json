{
  "ci": {
    "collect": {
      "staticDistDir": ".",
      "url": [
        "http://localhost/index.html",
        "http://localhost/impressum.html",
        "http://localhost/datenschutz.html",
        "http://localhost/barrierefreiheit.html"
      ],
      "numberOfRuns": 1,
      "settings": { "preset": "desktop" }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "categories:performance": ["warn", { "minScore": 0.8 }],
        "heading-order": "error",
        "html-has-lang": "error",
        "document-title": "error",
        "image-alt": "error",
        "link-name": "error",
        "button-name": "error"
      }
    }
  }
}
