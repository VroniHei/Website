# EditorConfig — einheitliche Formatierung über alle Editoren (VS Code, Claude, …)
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# In Markdown können zwei Leerzeichen am Zeilenende einen Umbruch bedeuten
trim_trailing_whitespace = false

[*.{svg,woff,woff2}]
insert_final_newline = false
